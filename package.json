{
  "name": "booksy-saas",
  "version": "0.1.0",
  "private": true,
  "description": "Multi-tenant appointment booking SaaS platform",
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "db:generate": "pnpm --filter ./packages/db exec prisma generate",
    "db:push": "cd packages/db && prisma db push",
    "db:migrate": "cd packages/db && prisma migrate dev",
    "db:seed": "cd packages/db && tsx src/seed.ts",
    "db:studio": "cd packages/db && prisma studio"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "turbo": "^2.0.0",
    "typescript": "^5.4.0"
  }
}
